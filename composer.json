{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "alexazartsev/heroicon": "^2.0",
        "alkoumi/laravel-hijri-date": "^1.0",
        "badinansoft/nova-language-switch": "^1.2",
        "barryvdh/laravel-dompdf": "^2.0.3",
        "carlos-meneses/laravel-mpdf": "^2.1",
        "devtical/nova-qrcode-field": "^2.0",
        "ebess/advanced-nova-media-library": "^4.4",
        "emilianotisato/nova-tinymce": "^2.0",
        "firebase/php-jwt": "^5.5",
        "google/apiclient": "^2.14",
        "guzzlehttp/guzzle": "^7.0.1",
        "laracasts/flash": "^3.2",
        "laravel/framework": "^10.0",
        "laravel/nova": "*",
        "laravel/tinker": "^2.8.1",
        "laravel/ui": "^4",
        "maatwebsite/laravel-nova-excel": "^1.3",
        "macsidigital/laravel-zoom": "^7.0.0",
        "mailgun/mailgun-php": "^3.5",
        "masbug/flysystem-google-drive-ext": "^2.4",
        "mirovit/nova-notifications": "^1.3",
        "mpdf/mpdf": "^8.2",
        "nyholm/psr7": "^1.5",
        "optimistdigital/nova-input-filter": "2.0.0",
        "optimistdigital/nova-multiselect-field": "^4.4.1",
        "outl1ne/nova-multiselect-field": "^4.4",
        "pion/laravel-chunk-upload": "^1.5",
        "pusher/pusher-php-server": "^5.0",
        "salla/zatca": "^2.0",
        "simonhamp/laravel-nova-csv-import": "^0.7.2",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "simplesquid/nova-advanced-number-field": "^3.1.0",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-analytics": "^5.5",
        "spatie/laravel-backup": "^8.6",
        "spatie/laravel-html": "^3.2",
        "spatie/laravel-medialibrary": "^10.15",
        "symfony/http-client": "^6.3",
        "symfony/mailgun-mailer": "^6.3",
        "titasgailius/search-relations": "^2.0",
        "whitecube/nova-flexible-content": "^1.1",
        "yajra/laravel-datatables": "^10.1",
        "yajra/laravel-datatables-oracle": "^10.8",
        "zfhassaan/genlytics": "^1.0"
    },
    "require-dev": {
        "spatie/laravel-ignition": "^2.0",
        "fzaninotto/faker": "^1.9.1",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^7.8.1",
        "phpunit/phpunit": "^10.3.1"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }

    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": {
        "0": {
            "type": "path",
            "url": "./nova"
        },
        "1": {
            "type": "path",
            "url": "./nova-components/MiamiIce"
        },
        "2": {
            "type": "path",
            "url": "./nova-components/MiamiIce"
        }

    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
