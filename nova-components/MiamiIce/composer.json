{
    "name": "admin/miami-ice",
    "description": "A Laravel Nova theme.",
    "keywords": [
        "laravel",
        "nova"
    ],
    "license": "MIT",
    "require": {
        "php": ">=7.1.0"
    },
    "autoload": {
        "psr-4": {
            "Admin\\MiamiIce\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Admin\\MiamiIce\\ThemeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
